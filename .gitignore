.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# Podman / Docker local runtime overrides 
# (Keeps your base compose.yaml in git, but ignores personal tweaks)
docker-compose.override.yml

# Operating system noise
.DS_Store
Thumbs.db