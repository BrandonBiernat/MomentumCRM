# Target directories (Build output)
**/bin/
**/obj/
**/out/

# AppBundle / Publish outputs
/**/Publish/
*.[Pp]ubxml
*.pubxml.user

# Look for user secrets and local config overrides
appsettings.Development.json
appsettings.Local.json
UserSecretsId

# Avoid tracking machine-specific developer settings
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates
.claude

# Podman / Docker local runtime overrides 
# (Keeps your base compose.yaml in git, but ignores personal tweaks)
docker-compose.override.yml

# Operating system noise
.DS_Store
Thumbs.db

logs/

# ---------------------------------------------------------------------------
# React / Node web project (MomentumCRM.Web) — patterns are recursive
# ---------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
*.local

# Vite / bundler caches
.vite/

# TypeScript incremental build info
*.tsbuildinfo

# Local env files (committed: .env, .env.development; ignored: *.local)
.env.local
.env.*.local

# JS package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage / lint caches
coverage/
.eslintcache